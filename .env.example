# ArangoDB Oasis Cluster Configuration
#
# Setup:
#   cp .env.example .env
#   # Edit .env with your actual credentials
#
# .env is gitignored and will not be committed.

ARANGO_ENDPOINT=https://your-cluster-id.arangodb.cloud:8529
ARANGO_USERNAME=root
ARANGO_PASSWORD=your-secure-password-here
ARANGO_DATABASE=network_assets_demo
