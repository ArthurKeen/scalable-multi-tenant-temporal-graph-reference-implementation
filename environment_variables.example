# ArangoDB Oasis Cluster Configuration
#
# Setup:
#   cp environment_variables.example setup_env.sh
#   # Edit setup_env.sh with your actual credentials
#   source setup_env.sh
#
# setup_env.sh is gitignored and will not be committed.

# ArangoDB Oasis cluster endpoint
export ARANGO_ENDPOINT=https://your-cluster-id.arangodb.cloud:8529

# Database credentials
export ARANGO_USERNAME=root
export ARANGO_PASSWORD=your-secure-password-here

# Database name (auto-created by the demo if it doesn't exist)
export ARANGO_DATABASE=network_assets_demo

# Security Note:
# - Never commit actual credentials to version control
# - Use environment variables or secure credential management
# - For production, consider using secrets management services
